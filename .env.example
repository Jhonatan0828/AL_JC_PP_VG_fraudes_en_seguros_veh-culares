# --------------------------------------------------------------
# Variables de entorno del proyecto
# Copia este archivo como .env y completa los valores reales.
# El archivo .env NO debe subirse a GitHub (está en .gitignore).
# --------------------------------------------------------------

# Rutas de datos (relativas a la raíz del proyecto)
RAW_DATA_PATH=data/raw/fraud_oracle.csv
PROCESSED_DATA_PATH=data/processed/fraud_clean.csv

# Etapa del modelo (dev | prod)
MODEL_STAGE=dev

# Configuración de Streamlit (opcional)
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
