*.py[cod]
*$py.class
*.so
.Python
build/
dist/
wheels/
*.egg-info/
.eggs/

# --------------------------------------------------------------
# Virtual environments
# --------------------------------------------------------------
.venv/
venv/
env/
ENV/

# --------------------------------------------------------------
# Jupyter
# --------------------------------------------------------------
.ipynb_checkpoints/
*.nbconvert.ipynb

# --------------------------------------------------------------
# Datos crudos pesados (Kaggle) — el dataset original NO se sube
# --------------------------------------------------------------
data/raw/*.csv
data/raw/*.xlsx

# Sí mantener el .gitkeep para conservar la estructura
!data/raw/.gitkeep

# NOTA: data/processed/fraud_clean.csv y models/*.pkl SÍ se incluyen
# en el repositorio porque son necesarios para que la app funcione
# en deploys (Streamlit Cloud, Heroku, etc.) sin tener que reentrenar.

